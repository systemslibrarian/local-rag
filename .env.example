# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL with the pgvector extension enabled
PG_DSN=postgresql+psycopg://user:password@localhost:5432/local_rag

# ── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=llama3.2
TEXT_EMBEDDING_MODEL=nomic-embed-text

# ── Vector store ─────────────────────────────────────────────────────────────
COLLECTION_NAME=local-rag

# ── File storage ─────────────────────────────────────────────────────────────
# PDFs are stored on disk here instead of in the database
FILE_STORAGE_FOLDER=./data/files
TEMP_FOLDER=/tmp/local-rag

# ── Retrieval tuning ─────────────────────────────────────────────────────────
# Minimum cosine-similarity score (0–1) for a chunk to be considered relevant
SIMILARITY_THRESHOLD=0.30
# Number of previous conversation turn messages included as LLM context
HISTORY_WINDOW=6

# ── DB connection pool ───────────────────────────────────────────────────────
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
